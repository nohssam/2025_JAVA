public class Goods {

	private int no;
	private String gname;
	private String desc;
	
	public Goods(){
		
	}
	
	public Goods(int  no, String  gname, String desc ){
		this.no = no;
		this.gname = gname;
		this.desc = desc;
	}
	
	public void output() {
